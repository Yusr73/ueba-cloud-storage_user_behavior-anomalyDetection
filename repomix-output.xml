<body>
    <div class="header">
        <div class="header-content">
            <div class="logo">
                <div class="logo-icon"><span>☁</span></div>
                <div class="logo-text">
                    <div class="primary">UEBA</div>
                    <div class="secondary">cloud storage</div>
                </div>
            </div>
            <div class="user-info">
                <span class="user-name" id="username"></span>
                <button class="btn-logout" onclick="logout()">Sign out</button>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="card">
            <div class="card-title">Upload files</div>
            <div class="upload-area">
                <input type="file" id="fileInput" multiple>
                <button class="btn-primary" onclick="uploadFiles()">Upload</button>
            </div>
        </div>

        <div class="tabs">
            <button class="tab active" onclick="showTab('files')">My files</button>
            <button class="tab" onclick="showTab('trash')">Trash</button>
        </div>

        <div id="files-tab">
            <div class="file-list">
                <div class="file-header">
                    <span>File name</span>
                    <span>Size</span>
                    <span>Actions</span>
                </div>
                <div id="files-container"></div>
            </div>
        </div>

        <div id="trash-tab" style="display:none;">
            <div class="file-list">
                <div class="file-header">
                    <span>File name</span>
                    <span>Size</span>
                    <span>Actions</span>
                </div>
                <div id="trash-container"></div>
            </div>
        </div>
    </div>

    <script>
        const token = localStorage.getItem('token');
        if (!token) window.location.href = '/login-page';
        document.getElementById('username').innerText = localStorage.getItem('user') || 'User';

        async function apiCall(url, options = {}) {
            const r = await fetch(url, {
                ...options,
                headers: { ...options.headers, 'Authorization': 'Bearer ' + token }
            });
            if (r.status === 401 || r.status === 403) {
                localStorage.removeItem('token');
                window.location.href = '/login-page';
                throw new Error('Unauthorized');
            }
            return r;
        }

        async function loadFiles() {
            try {
                const r = await apiCall('/files/list');
                const files = await r.json();
                const container = document.getElementById('files-container');
                if (files.length === 0) { container.innerHTML = '<div class="empty-state">No files uploaded yet</div>'; return; }
                container.innerHTML = files.map(f => `
                    <div class="file-item" id="file-item-${escapeHtml(f.name)}">
                        <div class="file-name" onclick="viewFile('${escapeHtml(f.name)}')">${escapeHtml(f.name)}</div>
                        <div class="file-size">${formatFileSize(f.size)}</div>
                        <div class="file-actions" id="actions-${escapeHtml(f.name)}">
                            <button class="btn-action btn-view" onclick="viewFile('${escapeHtml(f.name)}')">View</button>
                            <button class="btn-action btn-edit" onclick="editFile('${escapeHtml(f.name)}')">Edit</button>
                            <button class="btn-action btn-download" onclick="downloadFile('${escapeHtml(f.name)}')">Download</button>
                            <button class="btn-action btn-rename" onclick="showRenameInput('${escapeHtml(f.name)}')">Rename</button>
                            <button class="btn-action btn-share" onclick="shareFile('${escapeHtml(f.name)}')">Share</button>
                            <button class="btn-action btn-delete" onclick="deleteFile('${escapeHtml(f.name)}', false)">Delete</button>
                        </div>
                    </div>
                `).join('');
            } catch(e) { console.error(e); }
        }

        async function downloadFile(f) {
            const r = await apiCall(`/files/download/${encodeURIComponent(f)}`);
            const blob = await r.blob();
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a'); a.href = url; a.download = f;
            document.body.appendChild(a); a.click(); document.body.removeChild(a);
            URL.revokeObjectURL(url);
        }

        function showRenameInput(f) {
            const div = document.getElementById(`actions-${f}`);
            div.innerHTML = `<input type="text" id="rename-input-${f}" class="rename-input" value="${f}">
                <button class="rename-confirm" onclick="renameFile('${f}')">Save</button>
                <button class="rename-cancel" onclick="cancelRename('${f}')">Cancel</button>`;
            document.getElementById(`rename-input-${f}`).focus();
        }
        async function cancelRename(f) { await loadFiles(); }
        async function renameFile(oldF) {
            const newF = document.getElementById(`rename-input-${oldF}`).value;
            if (!newF || newF === oldF) { await loadFiles(); return; }
            try {
                const r = await apiCall(`/files/rename/${encodeURIComponent(oldF)}?new_filename=${encodeURIComponent(newF)}`, { method: 'PUT' });
                if (r.ok) { await loadFiles(); await loadTrash(); }
                else alert('Error renaming');
            } catch(e) { alert('Error'); }
        }

        async function loadTrash() {
            try {
                const r = await apiCall('/files/trash');
                const files = await r.json();
                const container = document.getElementById('trash-container');
                if (files.length === 0) { container.innerHTML = '<div class="empty-state">Trash bin is empty</div>'; return; }
                container.innerHTML = files.map(f => `
                    <div class="file-item">
                        <div class="file-name">${escapeHtml(f.name)}</div>
                        <div class="file-size">${formatFileSize(f.size)}</div>
                        <div class="file-actions">
                            <button class="btn-action btn-restore" onclick="restoreFile('${escapeHtml(f.name)}')">Restore</button>
                            <button class="btn-action btn-delete" onclick="deleteFile('${escapeHtml(f.name)}', true)">Delete</button>
                        </div>
                    </div>
                `).join('');
            } catch(e) { console.error(e); }
        }

        async function uploadFiles() {
            const files = document.getElementById('fileInput').files;
            if (!files.length) { alert('Select files'); return; }
            for (let file of files) {
                const fd = new FormData(); fd.append('file', file);
                await apiCall('/files/upload', { method: 'POST', body: fd });
            }
            alert('Uploaded'); document.getElementById('fileInput').value = ''; loadFiles();
        }

        function viewFile(f) { (f.split('.').pop().toLowerCase() === 'pdf') ? downloadFile(f) : window.location.href = `/editor/${f}`; }
        function editFile(f) { (f.split('.').pop().toLowerCase() === 'pdf') ? downloadFile(f) : window.location.href = `/editor/${f}`; }
        async function shareFile(f) {
            try {
                const r = await apiCall(`/files/${f}/share`, { method: 'POST' });
                const d = await r.json();
                prompt('Share link:', window.location.origin + d.share_link);
            } catch(e) { alert('Error'); }
        }
        async function deleteFile(f, perm) {
            if (!confirm(`Delete ${f}?`)) return;
            await apiCall(`/files/${f}?permanent=${perm}`, { method: 'DELETE' });
            loadFiles(); loadTrash();
        }
        async function restoreFile(f) {
            await apiCall(`/files/${f}/restore`, { method: 'POST' });
            loadFiles(); loadTrash();
        }

        function showTab(tab) {
            document.getElementById('files-tab').style.display = tab === 'files' ? 'block' : 'none';
            document.getElementById('trash-tab').style.display = tab === 'trash' ? 'block' : 'none';
            document.querySelectorAll('.tab').forEach((btn, i) => {
                if (i === 0) tab === 'files' ? btn.classList.add('active') : btn.classList.remove('active');
                else tab === 'trash' ? btn.classList.add('active') : btn.classList.remove('active');
            });
            loadFiles(); if (tab === 'trash') loadTrash();
        }

        function formatFileSize(b) {
            if (b === 0) return '0 Bytes';
            const k = 1024, sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(b) / Math.log(k));
            return parseFloat((b / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }
        function escapeHtml(t) { const d = document.createElement('div'); d.textContent = t; return d.innerHTML; }
        async function logout() {
            await apiCall('/logout', { method: 'POST' });
            localStorage.clear();
            window.location.href = '/login-page';
        }
        loadFiles();
    </script>
</body>
</html>
