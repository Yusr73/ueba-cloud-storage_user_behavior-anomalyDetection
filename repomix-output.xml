        "    if row['data_theft_verification']:\n",
        "        print(f\"    DATA_THEFT: {row['data_theft_verification']}\")\n",
        "    if row['login_verification']:\n",
        "        print(f\"    LOGIN: {row['login_verification']}\")\n",
        "    if row['bot_verification']:\n",
        "        print(f\"    BOT/MASS: {row['bot_verification']}\")"
