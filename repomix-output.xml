        "\n",
        "in_path = 'clue.json'               # input large file\n",
        "out_path = 'clue_sample_1GB.jsonl'  # output sampled file\n",
        "\n",
        "count, total_bytes = 0, 0\n",
        "with open(in_path, 'r') as fin, open(out_path, 'w') as fout:\n",
