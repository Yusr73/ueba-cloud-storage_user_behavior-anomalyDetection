        "import json\n",
        "import pandas as pd\n",
        "\n",
        "out_paths = {w: f\"clue_uids_{w}.jsonl\" for w in WINDOWS}\n",
        "outs = {w: open(path, \"w\", encoding=\"utf-8\") for w, path in out_paths.items()}\n",
        "\n",
        "counts = {w: 0 for w in WINDOWS}\n",
        "bad_json = 0\n",
        "bad_time = 0\n",
        "\n",
        "with open(FULL_JSONL, \"r\", encoding=\"utf-8\") as fin:\n",
