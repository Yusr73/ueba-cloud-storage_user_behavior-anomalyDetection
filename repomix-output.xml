<body>
    <div class="header">
        <div class="header-content">
            <div class="logo">
                <div class="logo-icon"><span>☁</span></div>
                <div class="logo-text"><div class="primary">UEBA</div><div class="secondary">cloud storage</div></div>
            </div>
            <div class="user-info">
                <span class="user-name" id="username"></span>
                <button class="btn-logout" onclick="logout()">Sign out</button>
            </div>
        </div>
    </div>

    <div class="container">
        <div id="stats-container"></div>
        <div id="admin-container"></div>
    </div>

    <script>
        const token = localStorage.getItem('token');
        const role = localStorage.getItem('role');
        if (!token) window.location.href = '/login-page';
        document.getElementById('username').innerText = localStorage.getItem('user') || 'User';

        if (role !== 'admin') {
            document.getElementById('stats-container').innerHTML = '';
            document.getElementById('admin-container').innerHTML = `<div class="access-denied"><h1>Access denied</h1><p>Administrator privileges required.</p><a href="/dashboard" style="color:#1a5a7a; font-weight:600;">← Back to Dashboard</a></div>`;
        } else {
            initAdmin();
        }

        async function apiCall(url, options = {}) {
            const r = await fetch(url, { ...options, headers: { ...options.headers, 'Authorization': 'Bearer ' + token } });
            if (!r.ok) throw new Error(r.status);
            return r.json();
        }

        async function loadStats() {
            const container = document.getElementById('stats-container');
            container.innerHTML = '<div class="empty-message">Loading...</div>';
            try {
                const data = await apiCall('/admin/api/stats');
                let html = `<div class="card"><div class="card-title">Database statistics</div><div class="stat-grid">`;
                for (const [table, count] of Object.entries(data.counts)) {
                    html += `<div class="stat-item"><div class="stat-label">${table.toUpperCase()}</div><div class="stat-number">${count}</div></div>`;
                }
                html += `</div></div>`;
                container.innerHTML = html;
            } catch(e) { container.innerHTML = '<div class="empty-message">Error loading stats</div>'; }
        }

        window.deleteRecord = async function(table, id) {
            if (!confirm(`Delete record ${id} from ${table}?`)) return;
            try {
                const r = await fetch(`/admin/api/table/${table}/${id}`, { method: 'DELETE', headers: { 'Authorization': 'Bearer ' + token } });
                const result = await r.json();
                if (result.success) { alert('Deleted'); loadStats(); loadTableData(); }
                else alert('Error: ' + result.error);
            } catch(e) { alert('Error'); }
        };

        async function loadTableData() {
            const table = document.getElementById('table-select').value;
            const container = document.getElementById('table-data');
            container.innerHTML = '<div class="empty-message">Loading...</div>';
            try {
                const data = await apiCall(`/admin/api/table/${table}`);
                if (!data.data || data.data.length === 0) { container.innerHTML = '<div class="empty-message">No records found</div>'; return; }
                let html = `<div class="table-wrapper"><table class="data-table"><thead><tr>`;
                for (const col of data.columns) html += `<th>${col.name}</th>`;
                html += `<th>Action</th></tr></thead><tbody>`;
                for (const row of data.data) {
                    html += `<tr>`;
                    for (const col of data.columns) {
                        let val = row[col.name];
                        if (val && typeof val === 'string' && val.length > 60) val = val.substring(0,57)+'...';
                        html += `<td title="${row[col.name]||''}">${val !== null && val !== undefined ? String(val).substring(0,60) : '-'}</td>`;
                    }
                    html += `<td><button class="btn-danger" onclick="deleteRecord('${table}', ${row.id})">Delete</button></td>`;
                    html += `</tr>`;
                }
                html += `</tbody></table></div>`;
                container.innerHTML = html;
            } catch(e) { container.innerHTML = '<div class="empty-message">Error loading table data</div>'; }
        }

        function initAdmin() {
            document.getElementById('admin-container').innerHTML = `
                <div class="card">
                    <div class="card-title">Database tables</div>
                    <div class="table-header">
                        <div class="table-title">Browse data</div>
                        <div class="table-controls">
                            <select id="table-select"><option value="users">Users</option><option value="logs">Logs</option><option value="files">Files</option><option value="shares">Shares</option></select>
                            <button onclick="loadTableData()">Load data</button>
                        </div>
                    </div>
                    <div id="table-data"></div>
                </div>
            `;
            loadStats();
            loadTableData();
        }

        async function logout() {
            await fetch('/logout', { method: 'POST', headers: { 'Authorization': 'Bearer ' + token } });
            localStorage.clear();
            window.location.href = '/login-page';
        }
    </script>
</body>
</html>
